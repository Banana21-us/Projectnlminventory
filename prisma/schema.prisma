generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & auth ────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  GUESTHOUSE
}

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  password           String
  role               Role       @default(STAFF)
  active             Boolean    @default(true)
  mustChangePassword Boolean    @default(false)
  createdById        String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  movements          Movement[]
  bookings           Booking[]
}

// ── Catalog ─────────────────────────────────────────────────────

enum CategoryType {
  BOOK
  MATERIAL
  SUPPLY
  ASSET
}

model Category {
  id     String       @id @default(cuid())
  name   String       @unique
  type   CategoryType
  active Boolean      @default(true)
  items  Item[]
}

model Stockroom {
  id        String      @id @default(cuid())
  name      String      @unique
  active    Boolean     @default(true)
  stocks    ItemStock[]
  movements Movement[]
}

model Item {
  id           String      @id @default(cuid())
  name         String
  model        String? // product model / edition, e.g. "3rd Edition" or "Sun King Pro 400"
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  unit         String      @default("pcs")
  // Money: avgCost maintained by weighted average on RECEIVE;
  // movements snapshot cost/price so history never changes.
  sellingPrice Decimal     @default(0) @db.Decimal(10, 2)
  avgCost      Decimal     @default(0) @db.Decimal(10, 2)
  minStock     Int         @default(0)
  frequent     Boolean     @default(false)
  // Per-unit serial tracking (assets only). When true, stock is issued and
  // returned by specific AssetUnit, not just quantity.
  serialized   Boolean     @default(false)
  notes        String?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  stocks       ItemStock[]
  movements    Movement[]
  assetUnits   AssetUnit[]
}

/// Per-stockroom stock level of an item. `quantity` is authoritative and
/// kept in lockstep with the sum of this row's Batch.qtyOnHand inside every
/// mutation transaction (see lib/stock.ts) — batches are lot/expiry detail,
/// not a second source of truth.
model ItemStock {
  id          String      @id @default(cuid())
  itemId      String
  item        Item        @relation(fields: [itemId], references: [id])
  stockroomId String
  stockroom   Stockroom   @relation(fields: [stockroomId], references: [id])
  shelf       String      @default("")
  quantity    Int         @default(0)
  maxStock    Int         @default(0)
  batches     Batch[]
  assetUnits  AssetUnit[]

  @@unique([itemId, stockroomId])
}

/// One receipt of stock into a stockroom. Dispensing drains batches FEFO
/// (earliest expiry first) when any batch on the item has an expiry, else
/// FIFO (earliest received first).
model Batch {
  id          String      @id @default(cuid())
  itemStockId String
  itemStock   ItemStock   @relation(fields: [itemStockId], references: [id])
  code        String // lot / batch label, e.g. "B-260712-A"
  qtyReceived Int
  qtyOnHand   Int
  receivedAt  DateTime    @default(now())
  expiry      DateTime?
  note        String?
  assetUnits  AssetUnit[]
  lines       MovementLine[]

  @@index([itemStockId])
}

enum AssetUnitStatus {
  IN_STOCK
  ISSUED
  WRITTEN_OFF
}

/// One physical, individually serialed unit of a serialized Item.
model AssetUnit {
  id      String          @id @default(cuid())
  itemId  String
  item    Item            @relation(fields: [itemId], references: [id])
  stockId String? // current ItemStock (stockroom) location; null once written off
  stock   ItemStock?      @relation(fields: [stockId], references: [id])
  batchId String?
  batch   Batch?          @relation(fields: [batchId], references: [id])
  serial  String
  status  AssetUnitStatus @default(IN_STOCK)
  lines   MovementLine[]

  @@unique([itemId, serial])
}

// ── Recipients ──────────────────────────────────────────────────

model District {
  id         String      @id @default(cuid())
  name       String      @unique
  active     Boolean     @default(true)
  recipients Recipient[]
}

enum RecipientType {
  PASTOR
  CHURCH
  MEMBER
  DEPARTMENT
  GUESTHOUSE
  OTHER
}

model Recipient {
  id         String        @id @default(cuid())
  name       String
  type       RecipientType @default(OTHER)
  email      String? // optional — used to email a dispense notice, mainly for PASTOR/GUESTHOUSE
  districtId String?
  district   District?     @relation(fields: [districtId], references: [id])
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  movements  Movement[]
}

// ── Movements (single audited ledger) ───────────────────────────

enum MovementType {
  RECEIVE
  DISPENSE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  WRITE_OFF
  RETURN
}

enum WriteOffReason {
  DAMAGED
  WET
  SPOILED
  EXPIRED
  LOST
  OTHER
}

model Movement {
  id             String           @id @default(cuid())
  itemId         String
  item           Item             @relation(fields: [itemId], references: [id])
  stockroomId    String
  stockroom      Stockroom        @relation(fields: [stockroomId], references: [id])
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  type           MovementType
  purpose        String?
  recipientId    String?
  recipient      Recipient?       @relation(fields: [recipientId], references: [id])
  issuedToName   String?
  qty            Int
  unitCost       Decimal          @default(0) @db.Decimal(10, 2)
  unitPrice      Decimal?         @db.Decimal(10, 2)
  orNumber       String?
  reference      String?
  // Set on WRITE_OFF (direct or via a bad-condition RETURN).
  writeOffReason WriteOffReason?
  note           String?
  // Set when a DISPENSE/SALE is voided; the compensating ADJUSTMENT row
  // (reference = this movement's id) carries who/when/why. Ledger stays
  // append-only — nothing is ever deleted.
  cancelledAt    DateTime?
  createdAt      DateTime         @default(now())
  lines          MovementLine[]

  @@index([itemId, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
}

/// Which batch (and, for serialized items, which unit) a movement drew
/// from or restocked into. Lets returns and write-offs put stock back into
/// / take it from the exact lot it came from, and shows lot/serial detail
/// in the log.
model MovementLine {
  id          String     @id @default(cuid())
  movementId  String
  movement    Movement   @relation(fields: [movementId], references: [id])
  batchId     String
  batch       Batch      @relation(fields: [batchId], references: [id])
  qty         Int
  assetUnitId String?
  assetUnit   AssetUnit? @relation(fields: [assetUnitId], references: [id])

  @@index([movementId])
}

// ── Guesthouse ──────────────────────────────────────────────────

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model Room {
  id       String     @id @default(cuid())
  name     String     @unique
  status   RoomStatus @default(AVAILABLE)
  bookings Booking[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

model Booking {
  id          String        @id @default(cuid())
  roomId      String
  room        Room          @relation(fields: [roomId], references: [id])
  guestName   String
  contact     String?
  checkIn     DateTime
  checkOut    DateTime
  status      BookingStatus @default(PENDING)
  note        String?
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([roomId, checkIn])
}
